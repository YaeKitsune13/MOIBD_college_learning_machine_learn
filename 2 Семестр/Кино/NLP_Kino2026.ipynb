        "## 3. Предобработка текста с оптимизацией"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 178,
      "id": "715f8293",
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Подготовка стоп-слов...\n",
            "✓ Стоп-слова подготовлены (всего: 176 слов)\n",
            "✓ Морфологический анализатор инициализирован\n"
          ]
        }
      ],
      "source": [
        "# Подготовка русских стоп-слов (оптимизированный список)\n",
        "print(\"Подготовка стоп-слов...\")\n",
        "\n",
        "try:\n",
        "    russian_stopwords = set(stopwords.words('russian'))\n",
        "except LookupError:\n",
        "    print(\"⬇️  Загрузка стоп-слов NLTK...\")\n",
        "    nltk.download('stopwords')\n",
        "    russian_stopwords = set(stopwords.words('russian'))\n",
        "\n",
        "# Расширенный список стоп-слов для лучшей фильтрации\n",
        "additional_stopwords = {\n",
        "    'т.д.', 'т', 'д', 'это', 'который', 'свой', 'своём',\n",
        "    'всем', 'всё', 'её', 'оба', 'ещё', 'должный', 'каждый',\n",
        "    'такой', 'каком', 'таком', 'таких', 'хороший', 'плохой',\n",
        "    'большой', 'маленький', 'новый', 'старый', 'первый', 'последний'\n",
        "}\n",
        "russian_stopwords.update(additional_stopwords)\n",
        "\n",
        "# Инициализация морфологического анализатора\n",
        "morph = pymorphy3.MorphAnalyzer()\n",
        "\n",
        "print(f\"✓ Стоп-слова подготовлены (всего: {len(russian_stopwords)} слов)\")\n",
        "print(f\"✓ Морфологический анализатор инициализирован\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 179,
      "id": "7358419d",
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "✓ Функции предобработки определены\n"
          ]
        }
      ],
      "source": [
        "# ==================== ФУНКЦИИ ПРЕДОБРАБОТКИ ====================\n",
        "\n",
        "def fun_punctuation_text(text):\n",
        "    \"\"\"\n",
        "    Шаг 1: Удаление пунктуации и нормализация текста\n",
        "    \"\"\"\n",
        "    text = '' if pd.isna(text) else str(text)\n",
        "    text = text.lower()\n",
        "    text = re.sub(r'[^а-яa-z\\s]', ' ', text)\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "    return text\n",
        "\n",
        "\n",
        "@lru_cache(maxsize=50000)\n",
        "def get_lemma(word):\n",
        "    \"\"\"Лемматизация с кэшированием\"\"\"\n",
        "    parsed = morph.parse(word)[0]\n",
        "    return parsed.normal_form if parsed.normal_form else word\n",
        "\n",
        "\n",
        "def fun_lemmatizing_text(text):\n",
        "    \"\"\"\n",
        "    Шаг 2: Лемматизация с использованием pymorphy3 и кэша\n",
        "    \"\"\"\n",
        "    if not text:\n",
        "        return ''\n",
        "    lemmatized = [get_lemma(token) for token in text.split() if len(token) > 1]\n",
        "    return ' '.join(lemmatized)\n",
        "\n",
        "\n",
        "def fun_tokenize(text):\n",
        "    \"\"\"\n",
        "    Шаг 3: Токенизация и удаление стоп-слов\n",
        "    \"\"\"\n",
        "    if not text:\n",
        "        return ''\n",
        "    \n",
        "    tokens = [\n",
        "        token for token in text.split() \n",
        "        if token not in russian_stopwords and len(token) > 2\n",
        "    ]\n",
        "    return ' '.join(tokens)\n",
        "\n",
        "\n",
        "def preprocess_text(text):\n",
        "    \"\"\"\n",
        "    Комплексная функция предобработки текста\n",
        "    \"\"\"\n",
        "    text = fun_punctuation_text(text)\n",
        "    text = fun_lemmatizing_text(text)\n",
        "    text = fun_tokenize(text)\n",
        "    return text\n",
        "\n",
        "\n",
        "print(\"✓ Функции предобработки определены\")"
      ]
    },
