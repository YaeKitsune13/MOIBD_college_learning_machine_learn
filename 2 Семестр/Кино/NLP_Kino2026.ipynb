      "source": [
        "# Поиск оптимального количества кластеров\n",
        "print(\"🔍 Поиск оптимального количества кластеров...\\n\")\n",
        "\n",
        "K_range = list(range(2, 11))\n",
        "wcss = []\n",
        "sil_scores = []\n",
        "inertias = []\n",
        "\n",
        "for k in K_range:\n",
        "    print(f\"  K={k}...\", end=\"\")\n",
        "    \n",
        "    km = KMeans(n_clusters=k, random_state=42, n_init=15, verbose=0)\n",
        "    labels = km.fit_predict(W)\n",
        "    \n",
        "    wcss.append(km.inertia_)\n",
        "    inertias.append(km.inertia_)\n",
        "    \n",
        "    # Вычисление силуэтного коэффициента\n",
        "    sil_score = silhouette_score(W, labels)\n",
        "    sil_scores.append(sil_score)\n",
        "    print(f\" Silhouette={sil_score:.4f}\")\n",
        "\n",
        "print(\"\\n✓ Анализ кластеризации завершен\")\n",
        "\n",
        "# Определение оптимального K\n",
        "optimal_k_silhouette = K_range[np.argmax(sil_scores)]\n",
        "best_silhouette_score = max(sil_scores)\n",
        "\n",
        "print(f\"\\n📊 Результаты:\")\n",
        "print(f\"  Оптимальный K (Silhouette): {optimal_k_silhouette}\")\n",
        "print(f\"  Лучший Silhouette Score: {best_silhouette_score:.4f}\")"
