        "\n",
        "# Настройка оптимизации\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "optimizer = optim.Adam(model_nn.parameters(), lr=0.001, weight_decay=1e-4)\n",
        "scheduler = optim.lr_scheduler.ReduceLROnPlateau(\n",
        "    optimizer, \n",
        "    mode='max', \n",
        "    factor=0.5, \n",
        "    patience=5\n",
        ")\n",
        "\n",
        "# Обучение\n",
        "epochs = EPOCHS\n",
        "train_losses = []\n",
        "val_accuracies = []\n",
