        "# Инициализация модели\n",
        "model_nn = MovieClassifierNN(\n",
        "    input_dim=X_train_scaled.shape[1],\n",
        "    hidden_dims=[512, 256, 128],\n",
        "    num_classes=n_topics,\n",
