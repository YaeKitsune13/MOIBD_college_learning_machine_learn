      "id": "predict_comparison",
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "✓ Функция предсказания определена\n"
          ]
        }
      ],
      "source": [
        "def predict_with_models(text, use_nn=True):\n",
        "    \"\"\"\n",
        "    Предсказание с использованием Random Forest и Neural Network\n",
        "    \"\"\"\n",
        "    # Предобработка\n",
        "    text_processed = preprocess_text(text)\n",
        "    text_vector = tfidf_loaded.transform([text_processed])\n",
        "    \n",
        "    # Random Forest\n",
        "    rf_pred = int(rf_model.predict(text_vector)[0])\n",
        "    rf_proba = rf_model.predict_proba(text_vector)[0]\n",
        "    rf_confidence = float(rf_proba[rf_pred])\n",
        "    \n",
        "    # Neural Network\n",
        "    if use_nn:\n",
        "        X_dense = text_vector.toarray().astype(np.float32)\n",
        "        X_scaled = scaler_loaded.transform(X_dense).astype(np.float32)\n",
        "        X_tensor = torch.from_numpy(X_scaled).to(device)\n",
        "        \n",
        "        with torch.no_grad():\n",
        "            output = nn_model_loaded(X_tensor)\n",
        "            nn_proba = F.softmax(output, dim=1).cpu().numpy()[0]\n",
        "            nn_pred = int(np.argmax(nn_proba))\n",
        "            nn_confidence = float(nn_proba[nn_pred])\n",
        "    else:\n",
        "        nn_pred, nn_proba, nn_confidence = None, None, None\n",
        "    \n",
        "    return {\n",
        "        'rf_pred': rf_pred,\n",
        "        'rf_proba': rf_proba,\n",
        "        'rf_confidence': rf_confidence,\n",
        "        'nn_pred': nn_pred,\n",
        "        'nn_proba': nn_proba,\n",
        "        'nn_confidence': nn_confidence\n",
        "    }\n",
        "\n",
        "\n",
        "print(\"✓ Функция предсказания определена\")"
      ]
    },
